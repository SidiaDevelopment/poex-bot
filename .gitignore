# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# Environment
.env
.env.local

# Database
*.sq3
apps/pollux/pollux

# Build files
.turbo
dist
node_modules

# Editor
.idea

**/dist
**/.turbo
.claude

# Stray TS build output next to sources (should only live in dist/).
# Safety net in case tsc is run without project refs and emits in-place.
**/src/**/*.js
**/src/**/*.js.map
**/src/**/*.d.ts
**/src/**/*.tsbuildinfo
