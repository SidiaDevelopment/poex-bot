{
  "name": "@pollux/pollux-framework",
  "version": "0.0.1",
  "description": "Pollux bot framework for easy bot development",
  "author": "Marvin Fischer <admin@sidia.net>",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidiaDevelopment/poex-bot",
    "directory": "."
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "turbo": "turbo build --output-logs new-only",
    "turbo:dev": "turbo watch build:dev  --output-logs new-only",
    "turbo:full": "turbo build test lint --output-logs new-only",
    "gen": "ts-node --esm ./scripts/gen.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.35.0",
    "@turbo/gen": "^2.9.3",
    "@types/eslint": "^9.6.1",
    "@types/nodemon": "^3.1.1",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.35.0",
    "execa": "^9.6.1",
    "nodemon": "^3.1.14",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "yargs": "^17.7.2"
  },
  "packageManager": "yarn@4.13.0"
}
